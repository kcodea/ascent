# Optional Supabase board backend (see docs/board-backend.md). The game runs fully offline without these —
# the committed OPPONENT_POOL_DATA is the floor; these just add the live shared pool.
# Copy this file to `.env.local` and fill in:
#   VITE_SUPABASE_URL       — Project Settings → Data API → Project URL (DROP the trailing /rest/v1/)
#   VITE_SUPABASE_ANON_KEY  — Project Settings → API Keys → the `publishable` (anon/public) key, NOT the secret
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
