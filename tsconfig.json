{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@game/core": ["packages/core/src/index.ts"],
      "@game/content": ["packages/content/src/index.ts"]
    }
  },
  "include": ["packages/*/src/**/*.ts"],
  // @game/ui is React/DOM (needs the DOM lib + jsx) — so it's a separate project, apps/web/tsconfig.json,
  // run by `npm run typecheck:web`. `npm run typecheck` runs BOTH; both are gated in CI.
  "exclude": ["packages/ui"]
}
