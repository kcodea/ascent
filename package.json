{
  "name": "ascent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ASCENT — single-player roguelike auto-battler. Deterministic engine + DOM UI.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "npm run typecheck:pkgs && npm run typecheck:web",
    "typecheck:pkgs": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "harness": "tsx packages/tools/src/combat-harness.ts",
    "bot": "tsx packages/tools/src/run-harness.ts",
    "replay": "tsx packages/tools/src/replay-harness.ts",
    "balance": "tsx packages/tools/src/balance.ts",
    "report": "tsx packages/tools/src/balance-report.ts",
    "analyze": "tsx packages/tools/src/balance-analysis.ts",
    "curve": "tsx packages/tools/src/enemy-curve.ts",
    "player": "tsx packages/tools/src/player-curve.ts",
    "audit": "tsx packages/tools/src/card-audit.ts",
    "perf": "tsx packages/tools/src/perf.ts",
    "pool": "tsx packages/tools/src/build-pool.ts",
    "pool:prune": "tsx packages/tools/src/prune-pool.ts",
    "sfx:import": "tsx packages/tools/src/sfx-import.ts",
    "sfx:manifest": "tsx packages/tools/src/sfx-manifest.ts",
    "dump-cards": "tsx packages/tools/src/dump-cards.ts",
    "optimize-art": "node scripts/optimize-art.mjs",
    "task": "node scripts/worktree.mjs new",
    "task:list": "node scripts/worktree.mjs list",
    "task:done": "node scripts/worktree.mjs done",
    "dev": "npm run dev -w apps/web",
    "build:web": "npm run build -w apps/web",
    "desktop": "npm run build:web && npm --workspace @game/desktop run start",
    "desktop:icon": "node scripts/make-icon.mjs",
    "package:desktop": "npm run build:web && node scripts/package-desktop.mjs",
    "package:itch:win": "npm run package:desktop && node scripts/package-itch-desktop.mjs",
    "package:itch": "npm run build:web && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-itch.ps1",
    "typecheck:web": "tsc -p apps/web/tsconfig.json --noEmit",
    "lint": "eslint .",
    "wire:plate": "node scripts/build-plate-wire.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "sharp": "^0.35.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
